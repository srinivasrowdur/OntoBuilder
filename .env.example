OPENAI_API_KEY=
GOOGLE_API_KEY=
ONTOLOGY_AGENT_PROVIDER=google
ONTOLOGY_AGENT_OPENAI_MODEL=openai:gpt-5.2
ONTOLOGY_AGENT_GOOGLE_MODEL=google:gemini-2.5-flash
ONTOLOGY_AGENT_MODEL=
# Cheap model that structures live-streamed drafts; set to "none" to disable
# entity streaming and use native structured output instead.
ONTOLOGY_AGENT_PARSER_MODEL=
# Base IRI for generated ontology namespaces, e.g. https://rowdur.com/ontology
ONTOLOGY_AGENT_BASE_IRI=
ONTOLOGY_AGENT_VECTOR_DB=none
ONTOLOGY_AGENT_DB_PATH=tmp/ontology-agent.db
ONTOLOGY_AGENT_VECTOR_PATH=tmp/ontology-agent-vectors
ONTOLOGY_AGENT_PROJECTS_PATH=projects
ONTOLOGY_AGENT_USER_ID=local-user
ONTOLOGY_AGENT_SESSION_ID=ontology-builder
ONTOLOGY_AGENT_TELEMETRY=false
ONTOLOGY_AGENT_DEBUG=false
